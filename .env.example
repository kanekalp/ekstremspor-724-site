NEXT_PUBLIC_MOCK_MODE=false

# ─── Postgres credentials ─────────────────────────────────────
# Compose reads these to provision the `db` service and to build
# the runtime DATABASE_URL for the web service.
POSTGRES_USER=extremspor
POSTGRES_PASSWORD=extremspor
POSTGRES_DB=extremspor

# For local non-docker runs (npm run dev), point at the compose
# DB exposed on the host: 127.0.0.1:5432.
DATABASE_URL=postgres://extremspor:extremspor@127.0.0.1:5432/extremspor

# ─── Session signing ──────────────────────────────────────────
# Long random string used to HMAC-sign session cookies. Regenerate
# with `openssl rand -hex 32`. Rotating invalidates all sessions.
SESSION_SECRET=
SESSION_COOKIE_NAME=extremspor_session
# Set to "true" only when serving over HTTPS. Leave blank for http://localhost
# (browsers reject Secure cookies over plain HTTP, silently breaking login).
SESSION_COOKIE_SECURE=

# ─── Admin access ─────────────────────────────────────────────
# Comma-separated admin emails: admin1@kampus.edu.tr,admin2@kampus.edu.tr
ADMIN_EMAILS=
# Plain-text admin login password (one shared password across the
# ADMIN_EMAILS list). Set to something non-trivial in production.
ADMIN_PASSWORD=

# ─── Student access ───────────────────────────────────────────
# Comma-separated email domains allowed to sign up as regular users.
# Empty = any email accepted.
ALLOWED_EMAIL_DOMAINS=std.yildiz.edu.tr

# ─── Uploads ──────────────────────────────────────────────────
# Where evidence screenshots are stored on disk. In docker this is a
# named volume mounted at /app/uploads; locally it's a folder under
# the project. Path must be writable by the Next.js process.
UPLOADS_DIR=./uploads
