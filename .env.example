NEXT_PUBLIC_MOCK_MODE=false

# ─── Supabase ─────────────────────────────────────────────────
# Local dev: leave hostname as 127.0.0.1 — the browser client rewrites
# the hostname to window.location.hostname at runtime so any LAN device
# pointing at the Next.js dev server (which runs on -H 0.0.0.0) hits
# Supabase on the same host:port without per-network env edits.
#
# Docker / production: point this at your cloud Supabase project, e.g.
#   NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# docker-compose reads NEXT_PUBLIC_* from this file (or .env) and
# passes them as build args so they get inlined into the client bundle.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Admin access ─────────────────────────────────────────────
# Comma-separated admin emails: admin1@kampus.edu.tr,admin2@kampus.edu.tr
ADMIN_EMAILS=
ADMIN_PASSWORD=

# ─── Student access ───────────────────────────────────────────
# Comma-separated email domains allowed to sign up as regular users
ALLOWED_EMAIL_DOMAINS=
